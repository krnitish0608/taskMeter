{
  "name": "taskMeter",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "start": "react-native start",
    "test": "jest",
    "postinstall": "patch-package",
    "dev": "cp .env.development .env && cp android/app/google-services.dev.json android/app/google-services.json && cp ios/taskMeter/GoogleService-Info.dev.plist ios/taskMeter/GoogleService-Info.plist && npm run start",
    "staging": "cp .env.staging .env && cp android/app/google-services.dev.json android/app/google-services.json && cp ios/taskMeter/GoogleService-Info.dev.plist ios/taskMeter/GoogleService-Info.plist && npm run start",
    "prod": "cp .env.production .env && cp android/app/google-services.prod.json android/app/google-services.json && cp ios/taskMeter/GoogleService-Info.prod.plist ios/taskMeter/GoogleService-Info.plist && npm run start"
  },
  "dependencies": {
    "@notifee/react-native": "^9.1.8",
    "@react-native-community/netinfo": "^12.0.1",
    "@react-native-firebase/app": "^23.8.6",
    "@react-native-firebase/auth": "^23.8.6",
    "@react-native-firebase/firestore": "^23.8.6",
    "@react-native-firebase/messaging": "^23.8.6",
    "@react-navigation/bottom-tabs": "^7.15.5",
    "@react-navigation/native": "^7.1.33",
    "@react-navigation/native-stack": "^7.14.4",
    "@reduxjs/toolkit": "^2.11.2",
    "react": "19.2.3",
    "react-native": "0.84.1",
    "react-native-config": "^1.6.1",
    "react-native-mmkv": "^4.2.0",
    "react-native-nitro-modules": "^0.35.0",
    "react-native-safe-area-context": "^5.5.2",
    "react-native-screens": "^4.24.0",
    "react-native-sqlite-storage": "^6.0.1",
    "react-native-vector-icons": "^10.3.0",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@babel/preset-env": "^7.25.3",
    "@babel/runtime": "^7.25.0",
    "@react-native-community/cli": "20.1.0",
    "@react-native-community/cli-platform-android": "20.1.0",
    "@react-native-community/cli-platform-ios": "20.1.0",
    "@react-native/babel-preset": "0.84.1",
    "@react-native/eslint-config": "0.84.1",
    "@react-native/metro-config": "0.84.1",
    "@react-native/typescript-config": "0.84.1",
    "@types/jest": "^29.5.13",
    "@types/react": "^19.2.0",
    "@types/react-native-sqlite-storage": "^6.0.5",
    "@types/react-native-vector-icons": "^6.4.18",
    "@types/react-test-renderer": "^19.1.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "eslint": "^8.19.0",
    "jest": "^29.6.3",
    "patch-package": "^8.0.1",
    "prettier": "2.8.8",
    "react-test-renderer": "19.2.3",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">= 22.11.0"
  }
}
